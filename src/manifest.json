{
  "manifest_version": 3,
  "name": "Precog",
  "version": "0.2.0.0",
  "description": "AI-powered actions on any webpage, with deep integrations for Gmail, Asana, Slack, and Claude",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Precog command palette"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["https://claude.ai/*"],
      "js": [
        "content/shared.js",
        "content/gmail.js",
        "content/asana.js",
        "content/slack.js",
        "content/generic.js",
        "content/loader.js"
      ],
      "css": ["content/precog.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
