{
  "manifest_version": 3,
  "name": "Precog",
  "version": "0.1.0.8",
  "description": "Automate tasks across Google Workspace, Asana, and Claude",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Precog command palette"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/shared.js", "content/gmail.js"],
      "css": ["content/gmail.css"]
    },
    {
      "matches": ["https://app.asana.com/*"],
      "js": ["content/shared.js", "content/asana.js"],
      "css": ["content/gmail.css"]
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
